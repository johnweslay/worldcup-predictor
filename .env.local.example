# ── Auth ──────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here   # openssl rand -base64 32

# Twitter / X OAuth 2.0
# Create app at: https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# ── Supabase ───────────────────────────────────────────
# Create project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Football Data API ──────────────────────────────────
# Free tier at: https://www.football-data.org/
FOOTBALL_API_KEY=your-football-data-api-key
FOOTBALL_API_BASE=https://api.football-data.org/v4
WORLD_CUP_COMPETITION_ID=2000   # FIFA World Cup ID

# ── Blockchain (for on-chain whitelist) ───────────────
# Alchemy / Infura RPC
BLOCKCHAIN_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
# Private key of wallet that owns the whitelist contract (NEVER commit this)
DEPLOYER_PRIVATE_KEY=0xyour-deployer-wallet-private-key
# Deployed contract address (fill after running: npx hardhat run scripts/deploy.js)
WHITELIST_CONTRACT_ADDRESS=0x...

# ── Cron security ─────────────────────────────────────
# Random secret used to protect the /api/cron/resolve endpoint
CRON_SECRET=your-cron-secret
